<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Robust.Client.UserInterface.Controls;assembly=Robust.Client"
    Title="{Loc stickers-window-title}"
    MinSize="300 200"
    SetSize="400 300"
    Resizable="True">
    <BoxContainer Orientation="Vertical" SeparationOverride="10" Margin="10" VerticalExpand="True">
        <!-- Stickers Grid -->
        <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
            <GridContainer Name="StickerGrid" Columns="4" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
